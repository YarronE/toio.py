# ===== Toio Pet Agent 配置 =====

# --- LLM 配置 ---
# 本地 Ollama (默认)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# 远程 LLM API (备选)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- AIGC 生图 API ---
IMAGE_GEN_PROVIDER=comfyui
# ComfyUI 本地
COMFYUI_BASE_URL=http://localhost:8188
# 或使用远程 API
IMAGE_GEN_API_KEY=
IMAGE_GEN_API_URL=

# --- AIGC 生3D模型 API ---
MODEL3D_GEN_PROVIDER=triposr
TRIPOSR_API_URL=http://localhost:8080
TRIPOSR_API_KEY=
# 或 Meshy
MESHY_API_KEY=

# --- Toio 蓝牙配置 ---
TOIO_AUTO_CONNECT=true
TOIO_MAX_CUBES=2
TOIO_SCAN_TIMEOUT=10

# --- 服务端口 ---
WEBSOCKET_PORT=8765
API_PORT=8000

# --- 桌面端配置 ---
DESKTOP_TRANSPARENT=true
DESKTOP_ALWAYS_ON_TOP=true
DESKTOP_PET_SIZE=128

# --- 日志 ---
LOG_LEVEL=INFO
LOG_FILE=logs/toio_pet.log
